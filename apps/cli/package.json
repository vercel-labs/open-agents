{
  "name": "@open-harness/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "openharness": "./index.ts"
  },
  "scripts": {
    "dev": "NODE_ENV=development bun run index.ts",
    "dev:vercel": "NODE_ENV=development bun run index.ts --sandbox=vercel",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@open-harness/agent": "workspace:*",
    "@open-harness/sandbox": "workspace:*",
    "@open-harness/shared": "workspace:*",
    "@opentui/core": "^0.1.75",
    "@opentui/react": "^0.1.75",
    "ai": "catalog:",
    "ink": "^6.6.0",
    "ink-spinner": "^5.0.0",
    "marked": "^17.0.1",
    "react": "^19.2.3"
  },
  "devDependencies": {
    "@ai-sdk/react": "catalog:",
    "@open-harness/tsconfig": "workspace:*",
    "@types/bun": "latest",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "oxlint": "^1.38.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
