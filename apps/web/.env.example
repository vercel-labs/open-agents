# Database
POSTGRES_URL=

# Encryption
JWE_SECRET=
ENCRYPTION_KEY=
# Required in production (32-byte hex). Dev has a fallback.
CLI_TOKEN_ENCRYPTION_KEY=

# Auth providers: "github", "vercel", or "github,vercel"
NEXT_PUBLIC_AUTH_PROVIDERS=github

# GitHub OAuth
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional integrations
ELEVENLABS_API_KEY=

# Redis (for resumable streams and stop signaling)
REDIS_URL=

# Vercel services (filled by scripts/setup.sh after `vc link`)
VERCEL_OIDC_TOKEN=
BLOB_READ_WRITE_TOKEN=
