{
  "name": "open-harness",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "cli": "bun run --cwd apps/cli dev",
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "turbo": "^2.5.4",
    "typescript": "^5"
  },
  "packageManager": "bun@1.2.14"
}
