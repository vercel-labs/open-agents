{
  "name": "open-harness",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "ai": "^6.0.27",
      "@ai-sdk/anthropic": "^3.0.1",
      "@ai-sdk/react": "^3.0.29",
      "zod": "^4.3.5"
    }
  },
  "overrides": {
    "zod": "^4.3.5"
  },
  "scripts": {
    "cli": "bun run --cwd apps/cli dev",
    "web": "cd apps/web/ && bun run dev",
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "turbo": "^2.5.4",
    "typescript": "^5"
  },
  "packageManager": "bun@1.2.14",
  "dependencies": {
    "@vercel/blob": "^2.0.0"
  }
}
