{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "import", "react"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-console": "off",
    "max-lines": [
      "error",
      {
        "max": 400,
        "skipBlankLines": true,
        "skipComments": true
      }
    ],
    "react/rules-of-hooks": "error",
    "react/exhaustive-deps": "warn",
    "typescript/no-explicit-any": "error"
  },
  "overrides": [
    {
      "files": [
        "apps/cli/tui/app.tsx",
        "apps/cli/tui/chat-context.tsx",
        "apps/cli/tui/components/input-box.tsx",
        "apps/cli/tui/components/question-panel.tsx",
        "apps/cli/tui/components/text-input.tsx",
        "apps/cli/tui/components/tool-renderers/shared.tsx",
        "packages/agent/system-prompt.ts",
        "packages/agent/tools/tools.test.ts",
        "packages/sandbox/hybrid/sandbox.ts",
        "packages/sandbox/just-bash/sandbox.ts",
        "packages/sandbox/vercel/sandbox.test.ts",
        "packages/sandbox/vercel/sandbox.ts"
      ],
      "rules": {
        "max-lines": [
          "warn",
          {
            "max": 400,
            "skipBlankLines": true,
            "skipComments": true
          }
        ]
      }
    }
  ]
}
