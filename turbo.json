{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "POSTGRES_URL",
        "NEXT_PUBLIC_AUTH_PROVIDERS",
        "NEXT_PUBLIC_VERCEL_APP_CLIENT_ID",
        "VERCEL_APP_CLIENT_SECRET",
        "NEXT_PUBLIC_GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "JWE_SECRET",
        "CLI_TOKEN_ENCRYPTION_KEY",
        "BLOB_READ_WRITE_TOKEN"
      ],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"],
      "outputs": []
    }
  }
}
