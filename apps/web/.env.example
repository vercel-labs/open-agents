# Database
POSTGRES_URL=

# Encryption
JWE_SECRET=
ENCRYPTION_KEY=

# Auth providers: "vercel", "github", or "vercel,github"
NEXT_PUBLIC_AUTH_PROVIDERS=vercel

# Vercel OAuth (primary sign-in)
NEXT_PUBLIC_VERCEL_APP_CLIENT_ID=
VERCEL_APP_CLIENT_SECRET=

# GitHub App (repo access via installation + user authorization)
# In the GitHub App settings:
#   1. Enable "Request user authorization (OAuth) during installation"
#   2. Set Callback URL to: {YOUR_ORIGIN}/api/github/app/callback
#   3. Set Setup URL to:    {YOUR_ORIGIN}/api/github/app/callback
#   4. Make the app public (Danger Zone > "Make public") so that users
#      can install it on organizations, not just the owner's account.
#      While the app is private, the install flow only shows the owner's
#      personal account -- no org picker.
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# Optional integrations
ELEVENLABS_API_KEY=

# Redis (for resumable streams and stop signaling)
REDIS_URL=

# Vercel services (filled by scripts/setup.sh after `vc link`)
VERCEL_OIDC_TOKEN=
BLOB_READ_WRITE_TOKEN=
